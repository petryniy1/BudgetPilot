<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.BudgetPilot.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/budget_pilot_launch_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_budget_pilot_splash</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/budget_pilot_launch_icon_background</item>
        <item name="postSplashScreenTheme">@style/Theme.BudgetPilot</item>
    </style>

    <style name="Theme.BudgetPilot" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/budget_pilot_accent_blue</item>
        <item name="colorPrimaryVariant">@color/budget_pilot_launch_background</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/budget_pilot_accent_blue</item>
        <item name="colorSecondaryVariant">@color/budget_pilot_dark_blue</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/budget_pilot_launch_background</item>
        <item name="android:navigationBarColor">@color/budget_pilot_launch_background</item>
        <item name="android:windowFullscreen">true</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
</resources>
